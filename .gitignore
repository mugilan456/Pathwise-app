extension DateTimeExtensions on DateTime {
  String toFormattedString() {
    final months = [
      'Jan',
      'Feb',
      'Mar',
      'Apr',
      'May',
      'Jun',
      'Jul',
      'Aug',
      'Sep',
      'Oct',
      'Nov',
      'Dec'
    ];
    return '$day ${months[month - 1]} $year';
  }
}
